# Copy to .env and adjust (optional). The orchestrator reads OLLAMA_HOST if set.
# Do not commit real secrets.

# Ollama API base URL (overrides config/models.json ollama_base_url when set)
OLLAMA_HOST=http://127.0.0.1:11434

# When set to 1, route LLM calls through `opencode run` instead of direct Ollama HTTP.
# Requires `opencode` on PATH and a working opencode.json. See docs/INTEGRATION-OPENCODE.md
# OPENCODE_RUNTIME=0

# Optional: point OpenCode at a specific config file (OpenCode standard)
# OPENCODE_CONFIG=/path/to/opencode.json
